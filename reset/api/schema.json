{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DataRecord",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique identifier"
    },
    "name": {
      "type": "string",
      "maxLength": 255
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive", "pending"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["id", "name", "status"]
}
